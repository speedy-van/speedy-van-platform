{
  "name": "speedyvan",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "npm run build -w packages/db && npm run build -w apps/web && npm run build -w apps/api",
    "db:generate": "npm run db:generate -w packages/db",
    "db:push": "npm run db:push -w packages/db",
    "db:seed": "npm run db:seed -w packages/db",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "react-icons": "^5.6.0"
  }
}
