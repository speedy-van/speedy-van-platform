// Speedy Van — Phase 2 schema (PostgreSQL on Neon)
// All models needed for Hono.js API: auth, bookings, pricing, items,
// driver job board, tracking, chat, visitors, notifications, content CMS.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  DRIVER
  CUSTOMER
}

enum VanSize {
  SMALL
  MEDIUM
  LARGE
  LUTON
}

enum BookingStatus {
  PENDING       // awaiting payment
  CONFIRMED     // paid, awaiting driver
  ASSIGNED      // driver accepted job
  IN_PROGRESS   // driver en route / loading / in transit
  COMPLETED
  CANCELLED
}

enum JobStatus {
  AVAILABLE          // visible on job board
  ACCEPTED           // assigned, not yet started
  DRIVER_EN_ROUTE
  ARRIVED_PICKUP
  LOADING
  IN_TRANSIT
  ARRIVED_DROPOFF
  UNLOADING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  NEW_BOOKING
  DRIVER_ASSIGNED
  JOB_COMPLETED
  HIGH_TRAFFIC
  PAYMENT_FAILED
  CHAT_MESSAGE
  GENERIC
}

enum ConversationParticipantRole {
  CUSTOMER
  DRIVER
  ADMIN
}

// ─── Core ─────────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  phone            String?
  password         String    // bcrypt hash; nullable-style accounts use a placeholder
  role             Role      @default(CUSTOMER)
  isActive         Boolean   @default(true)
  stripeCustomerId String?
  pushToken        String?
  pushPlatform     String?   // "ios" | "android"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bookings           Booking[]
  reviews            Review[]
  driver             Driver?
  notifications      Notification[]
  passwordResets     PasswordResetToken[]
  conversationParts  ConversationParticipant[]
  messagesSent       Message[]                  @relation("MessageSender")
  trackingActor      TrackingEvent[]            @relation("TrackingActor")
  statusChangedBy    StatusHistory[]            @relation("StatusChangedBy")
}

model Driver {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id])
  vanSize   VanSize   @default(MEDIUM)
  isActive  Boolean   @default(true)
  bookings  Booking[]
  jobs      DriverJob[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  icon        String    @default("📦")
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Service {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  isActive    Boolean   @default(true)
  bookings    Booking[]
  pricing     Pricing[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Area {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  region      String
  description String
  isActive    Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Pricing {
  id        String   @id @default(cuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])
  vanSize   VanSize
  basePrice Float
  perHour   Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, vanSize])
}

// ─── Pricing engine config (key/value with category grouping) ─────────────────

model PricingConfig {
  id          String   @id @default(cuid())
  category    String   // "distance" | "floor" | "urgency" | "weekend" | "season" | "weather" | "addon" | "variant" | "tier"
  key         String   // e.g. "perMileRate", "freeMiles", "morningMultiplier"
  value       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, key])
  @@index([category])
}

// ─── Items (per-item catalog with images) ─────────────────────────────────────

model ItemCategory {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  icon      String?
  type      String   @default("both") // "residential" | "business" | "both"
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id          String       @id @default(cuid())
  categoryId  String
  category    ItemCategory @relation(fields: [categoryId], references: [id])
  slug        String       @unique
  name        String
  imagePath   String?
  weight      Float?       // kg
  size        String?      // "small" | "medium" | "large" | "xl"
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  bookingItems BookingItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── Booking (full Phase 2) ───────────────────────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  reference   String        @unique // SVR-YYYY-XXXXXX

  // customer
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  customerName  String
  customerEmail String
  customerPhone String

  // service
  serviceId      String
  service        Service     @relation(fields: [serviceId], references: [id])
  serviceSlug    String
  serviceName    String
  serviceVariant String?

  // area (kept for back-compat with Phase 1)
  areaId String
  area   Area   @relation(fields: [areaId], references: [id])

  // pickup
  pickupAddress  String
  pickupPostcode String
  pickupLat      Float
  pickupLng      Float
  pickupFloor    Int      @default(0)
  pickupHasLift  Boolean  @default(false)

  // dropoff
  dropoffAddress  String
  dropoffPostcode String
  dropoffLat      Float
  dropoffLng      Float
  dropoffFloor    Int      @default(0)
  dropoffHasLift  Boolean  @default(false)

  distanceMiles Float    @default(0)

  // schedule
  scheduledAt      DateTime
  selectedDate     DateTime?
  selectedTimeSlot String?  // "morning" | "afternoon" | "evening"

  // options
  helpersCount   Int     @default(0)
  needsPacking   Boolean @default(false)
  needsAssembly  Boolean @default(false)

  // pricing & payment
  price              Float
  totalPrice         Float    @default(0)
  isPaid             Boolean  @default(false)
  paidAt             DateTime?
  stripePaymentId    String?
  refundAmount       Float    @default(0)

  // assignment
  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id])

  // status
  status BookingStatus @default(PENDING)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  items           BookingItem[]
  job             DriverJob?
  trackingEvents  TrackingEvent[]
  statusHistory   StatusHistory[]
  conversation    Conversation?
  review          Review?
}

model BookingItem {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?   @relation(fields: [itemId], references: [id])
  name      String
  quantity  Int     @default(1)
  createdAt DateTime @default(now())

  @@index([bookingId])
}

// ─── Driver job board ─────────────────────────────────────────────────────────

model DriverJob {
  id         String    @id @default(cuid())
  bookingId  String    @unique
  booking    Booking   @relation(fields: [bookingId], references: [id])
  driverId   String?
  driver     Driver?   @relation(fields: [driverId], references: [id])
  status     JobStatus @default(AVAILABLE)
  isPublic   Boolean   @default(true)
  acceptedAt DateTime?
  startedAt  DateTime?
  completedAt DateTime?
  rejectionReason String?
  driverPay       Float?
  driverPayStatus String   @default("unpaid")
  driverPayNotes  String?
  proofImageUrl   String?
  notes           String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([status, isPublic])
  @@index([driverId])
}

// ─── Tracking events (status + location) ──────────────────────────────────────

model TrackingEvent {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type        String   // "status" | "location" | "note" | "system"
  status      String?  // when type=status (the new status)
  message     String?
  lat         Float?
  lng         Float?
  isInternal  Boolean  @default(false) // internal admin notes
  actorId     String?
  actor       User?    @relation("TrackingActor", fields: [actorId], references: [id])
  actorRole   String?
  createdAt   DateTime @default(now())

  @@index([bookingId, createdAt])
}

model StatusHistory {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  changedById String?
  changedBy   User?    @relation("StatusChangedBy", fields: [changedById], references: [id])
  changedByRole String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([bookingId, createdAt])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Conversation {
  id           String                    @id @default(cuid())
  bookingId    String                    @unique
  booking      Booking                   @relation(fields: [bookingId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String                       @id @default(cuid())
  conversationId String
  conversation   Conversation                 @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                         @relation(fields: [userId], references: [id])
  role           ConversationParticipantRole
  lastReadAt     DateTime?
  createdAt      DateTime                     @default(now())

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String           // recipient
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

// ─── Visitor tracking ─────────────────────────────────────────────────────────

model Visitor {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  userAgent     String?
  referrer      String?
  landingPage   String?
  screenWidth   Int?
  isActive      Boolean  @default(true)
  totalDuration Int      @default(0) // seconds
  pageViews     Int      @default(0)
  createdAt     DateTime @default(now())
  lastActiveAt  DateTime @default(now())
  exitedAt      DateTime?
  events        VisitorEvent[]

  @@index([isActive, lastActiveAt])
}

model VisitorEvent {
  id        String   @id @default(cuid())
  visitorId String
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  type      String   // "page_view" | "click" | "form_submit" | ...
  page      String?
  element   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([visitorId, createdAt])
}

// ─── Content CMS ──────────────────────────────────────────────────────────────

model Content {
  id        String   @id @default(cuid())
  section   String
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, key])
  @@index([section])
}

// ─── Password reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
