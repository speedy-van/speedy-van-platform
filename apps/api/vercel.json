{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx prisma generate",
  "builds": [
    {
      "src": "_api.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["node_modules/@prisma/client/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "_api.js"
    }
  ]
}
